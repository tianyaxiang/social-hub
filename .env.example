# Chrome DevTools Protocol
CDP_HOST=localhost
CDP_PORT=9222

# Browser Mode: 'cdp' | 'playwright'
# - cdp: Use existing Chrome via DevTools Protocol (reuses logged-in sessions)
# - playwright: Use headless Playwright browser (isolated, requires stored sessions)
BROWSER_MODE=playwright

# Encryption key for session data (generate with: openssl rand -hex 32)
SESSION_ENCRYPT_KEY=

# Database
DATABASE_URL=./data/social-hub.db
